# =============================================
# Anurag University Exam Hall Locator - Backend
# =============================================

# Database (Neon / Supabase / Railway PostgreSQL)
# Get from: https://neon.tech OR https://supabase.com OR https://railway.app
DB_URL=jdbc:postgresql://<host>/<dbname>?sslmode=require
DB_USER=your_db_username
DB_PASS=your_db_password

# JWT Secret (use a long random string, min 32 characters)
JWT_SECRET=your_very_long_jwt_secret_key_minimum_32_characters_long

# JWT Expiration (in ms) - 86400000 = 24 hours
JWT_EXPIRATION=86400000

# Twilio (Get from https://console.twilio.com)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# CORS - Frontend URL (comma-separated for multiple)
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://your-frontend.vercel.app

# Server Port (Render sets this automatically)
PORT=8080
